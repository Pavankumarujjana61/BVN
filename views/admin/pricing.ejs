<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Pricing | BVN Modulars CMS</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <div class="admin-layout">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="admin-logo-wrapper" style="text-align: center; margin-bottom: 2rem;">
        <img src="/images/logo.png" alt="BVN Modulars" class="admin-sidebar-logo" style="max-height: 50px; width: auto; object-fit: contain;">
      </div>
      <ul class="admin-menu">
        <li><a href="/admin">Dashboard</a></li>
        <li><a href="/admin/projects">Manage Projects</a></li>
        <li><a href="/admin/testimonials">Manage Reviews</a></li>
        <li class="active"><a href="/admin/pricing">Manage Pricing</a></li>
        <li><a href="/admin/blogs">Manage Blogs</a></li>
        <li><a href="/admin/banners">Manage Banners</a></li>
        <li><a href="/admin/enquiries">Enquiries</a></li>
        <li><a href="/admin/settings">Settings</a></li>
      </ul>
      <div class="admin-logout">
        <a href="/" target="_blank" style="color: var(--bg-offwhite); display: block; margin-bottom: 1rem;">View Website &rarr;</a>
        <a href="/admin/logout">Logout</a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="admin-main">
      <header class="admin-header">
        <h1>Manage Pricing Packages</h1>
        <div>Administrator</div>
      </header>

      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>

      <div style="display: flex; flex-direction: column; gap: 2.5rem;">
        <% pricing.forEach(pkg => { %>
          <div class="admin-card">
            <h3 style="margin-bottom: 1.5rem; color: var(--primary-oxblood); border-bottom: 1px solid var(--bg-offwhite); padding-bottom: 0.5rem;">
              <%= pkg.name %> <%= pkg.isPopular ? '(Highlighted Package)' : '' %>
            </h3>
            
            <form action="/admin/pricing/update/<%= pkg.id %>" method="POST">
              <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 2rem;">
                <!-- Left side -->
                <div>
                  <div class="form-group">
                    <label for="startingPrice_<%= pkg.id %>">Starting Price (in Lakhs) *</label>
                    <input type="number" step="0.01" id="startingPrice_<%= pkg.id %>" name="startingPrice" class="form-control" value="<%= pkg.startingPrice %>" required>
                    <p style="font-size: 0.8rem; color: var(--secondary-walnut); margin-top: 0.25rem;">Enter the number in Lakhs. E.g., enter <strong>2.50</strong> for ₹2.50 Lakhs (₹2,50,000), or <strong>1.25</strong> for ₹1.25 Lakhs.</p>
                  </div>
                  
                  <div class="form-group" style="margin-top: 1rem;">
                    <label>Highlight Status</label>
                    <div style="margin-top: 0.5rem;">
                      <label style="display: inline-flex; align-items: center; font-weight: normal; font-size: 0.95rem; cursor: pointer;">
                        <input type="checkbox" name="isPopular" value="true" <%= pkg.isPopular ? 'checked' : '' %> style="margin-right: 0.5rem; transform: scale(1.1);"> Highlight as 'Most Popular'
                      </label>
                    </div>
                  </div>
                </div>

                <!-- Right side -->
                <div>
                  <div class="form-group">
                    <label for="inclusions_<%= pkg.id %>">Package Inclusions (One per line) *</label>
                    <textarea id="inclusions_<%= pkg.id %>" name="inclusions" class="form-control" style="min-height: 150px;" required><%= pkg.inclusions.join('\n') %></textarea>
                    <p style="font-size: 0.8rem; color: var(--secondary-walnut); margin-top: 0.25rem;">Enter each feature, brand specification, or room layout item on a new line.</p>
                  </div>
                </div>
              </div>
              
              <div style="text-align: right; margin-top: 1.5rem; border-top: 1px solid var(--bg-offwhite); padding-top: 1rem;">
                <button type="submit" class="btn btn-primary btn-sm">Update <%= pkg.name %></button>
              </div>
            </form>
          </div>
        <% }) %>
      </div>
    </main>
  </div>

</body>
</html>
