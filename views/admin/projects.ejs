<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Projects | BVN Modulars CMS</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <div class="admin-layout">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="admin-logo-wrapper" style="text-align: center; margin-bottom: 2rem;">
        <img src="/images/logo.png" alt="BVN Modulars" class="admin-sidebar-logo" style="max-height: 50px; width: auto; object-fit: contain;">
      </div>
      <ul class="admin-menu">
        <li><a href="/admin">Dashboard</a></li>
        <li class="active"><a href="/admin/projects">Manage Projects</a></li>
        <li><a href="/admin/testimonials">Manage Reviews</a></li>
        <li><a href="/admin/blogs">Manage Blogs</a></li>
        <li><a href="/admin/banners">Manage Banners</a></li>
        <li><a href="/admin/enquiries">Enquiries</a></li>
        <li><a href="/admin/settings">Settings</a></li>
      </ul>
      <div class="admin-logout">
        <a href="/" target="_blank" style="color: var(--bg-offwhite); display: block; margin-bottom: 1rem;">View Website &rarr;</a>
        <a href="/admin/logout">Logout</a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="admin-main">
      <header class="admin-header">
        <h1>Manage Project Gallery</h1>
        <div>Administrator</div>
      </header>

      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>

      <div class="admin-form-grid" style="grid-template-columns: 1.2fr 1.8fr; align-items: start;">
        <!-- Edit / Add Project Form -->
        <div class="admin-card">
          <% if (typeof editProject !== 'undefined' && editProject) { %>
            <h3 style="margin-bottom: 1.5rem; color: var(--primary-oxblood);">Edit Project</h3>
            <form action="/admin/projects/edit/<%= editProject.id %>" method="POST" enctype="multipart/form-data">
              <div class="form-group">
                <label for="title">Project Title *</label>
                <input type="text" id="title" name="title" class="form-control" value="<%= editProject.title %>" placeholder="e.g. Premium High-Gloss Kitchen" required>
              </div>

              <div class="form-group">
                <label for="category">Gallery Category *</label>
                <select id="category" name="category" class="form-control" required>
                  <option value="modular-kitchens" <%= editProject.category === 'modular-kitchens' ? 'selected' : '' %>>Modular Kitchens</option>
                  <option value="wardrobes" <%= editProject.category === 'wardrobes' ? 'selected' : '' %>>Wardrobes</option>
                  <option value="tv-units" <%= editProject.category === 'tv-units' ? 'selected' : '' %>>TV Units</option>
                  <option value="bedrooms" <%= editProject.category === 'bedrooms' ? 'selected' : '' %>>Bedrooms</option>
                  <option value="crockery-units" <%= editProject.category === 'crockery-units' ? 'selected' : '' %>>Crockery Units</option>
                  <option value="office-interiors" <%= editProject.category === 'office-interiors' ? 'selected' : '' %>>Office Interiors</option>
                </select>
              </div>

              <div class="form-group">
                <label for="location">Location *</label>
                <input type="text" id="location" name="location" class="form-control" value="<%= editProject.location %>" required>
              </div>

              <div class="form-group">
                <label for="projectImage">Project Photograph (Leave empty to keep current)</label>
                <input type="file" id="projectImage" name="projectImage" class="form-control" accept="image/*">
                <div style="margin-top: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
                  <span style="font-size: 0.8rem; color: var(--secondary-walnut);">Current Photo:</span>
                  <img src="<%= editProject.image %>" alt="" style="width: 80px; height: 55px; object-fit: cover; border-radius: 4px; border: 1.5px solid var(--secondary-walnut);">
                </div>
              </div>

              <div class="form-group">
                <label for="description">Description *</label>
                <textarea id="description" name="description" class="form-control" placeholder="Details of materials, colors, layout etc." required><%= editProject.description %></textarea>
              </div>

              <button type="submit" class="btn form-submit-btn">Update Project</button>
              <a href="/admin/projects" class="btn btn-secondary" style="display: block; text-align: center; text-decoration: none; margin-top: 0.75rem; padding: 0.75rem 1rem; border: 1px solid var(--secondary-walnut); border-radius: 4px; color: var(--secondary-walnut); font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 0.9rem; background: transparent;">Cancel Edit</a>
            </form>
          <% } else { %>
            <h3 style="margin-bottom: 1.5rem; color: var(--primary-oxblood);">Add New Project</h3>
            <form action="/admin/projects/add" method="POST" enctype="multipart/form-data">
              <div class="form-group">
                <label for="title">Project Title *</label>
                <input type="text" id="title" name="title" class="form-control" placeholder="e.g. Premium High-Gloss Kitchen" required>
              </div>

              <div class="form-group">
                <label for="category">Gallery Category *</label>
                <select id="category" name="category" class="form-control" required>
                  <option value="modular-kitchens">Modular Kitchens</option>
                  <option value="wardrobes">Wardrobes</option>
                  <option value="tv-units">TV Units</option>
                  <option value="bedrooms">Bedrooms</option>
                  <option value="crockery-units">Crockery Units</option>
                  <option value="office-interiors">Office Interiors</option>
                </select>
              </div>

              <div class="form-group">
                <label for="location">Location *</label>
                <input type="text" id="location" name="location" class="form-control" value="Rajahmundry" required>
              </div>

              <div class="form-group">
                <label for="projectImage">Project Photograph *</label>
                <input type="file" id="projectImage" name="projectImage" class="form-control" accept="image/*" required>
                <p style="font-size: 0.8rem; color: var(--secondary-walnut); margin-top: 0.25rem;">Landscape orientation, under 300KB (WebP/JPEG/PNG) preferred.</p>
              </div>

              <div class="form-group">
                <label for="description">Description *</label>
                <textarea id="description" name="description" class="form-control" placeholder="Details of materials, colors, layout etc." required></textarea>
              </div>

              <button type="submit" class="btn form-submit-btn">Save Project</button>
            </form>
          <% } %>
        </div>

        <!-- Project Listing -->
        <div class="admin-card">
          <h3 style="margin-bottom: 1.5rem; color: var(--primary-oxblood);">Current Project Images</h3>
          <table class="admin-table">
            <thead>
              <tr>
                <th>Image</th>
                <th>Title / Category</th>
                <th>Location</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% projects.forEach(project => { %>
                <tr>
                  <td>
                    <img src="<%= project.image %>" alt="<%= project.title %>" style="width: 80px; height: 55px; object-fit: cover; border-radius: 4px;">
                  </td>
                  <td>
                    <strong><%= project.title %></strong><br>
                    <span style="font-size: 0.8rem; color: var(--secondary-walnut);"><%= project.category %></span>
                  </td>
                  <td><%= project.location %></td>
                  <td>
                    <div style="display: flex; gap: 0.5rem; align-items: center;">
                      <a href="/admin/projects?edit=<%= project.id %>" class="btn btn-primary btn-sm" style="text-decoration: none; display: inline-block;">Edit</a>
                      <form action="/admin/projects/delete/<%= project.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this project?');" style="margin: 0;">
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

</body>
</html>
