      <!-- Milestone 4 -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; position: relative; z-index: 2;" class="reveal reveal-right">
        <div></div>
        <div style="text-align: left; padding-left: 2rem;">
          <div style="font-family: 'Montserrat'; font-weight: 700; font-size: 1.5rem; color: var(--primary-oxblood);">2026</div>
          <h4 style="color: var(--secondary-walnut); font-weight: 600; margin-top: 0.25rem;">AP Market Leader</h4>
          <p style="font-size: 0.95rem; margin-top: 0.5rem;">Celebrated 1,200+ completed projects. Expanded local sales to cover Rajahmundry, Kakinada, and Vijayawada.</p>
        </div>
      </div>
    </div>
  </div>
</section>

