      <!-- Milestone 3 -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; position: relative; z-index: 2;" class="reveal reveal-left">
        <div style="text-align: right; padding-right: 2rem;">
          <div style="font-family: 'Montserrat'; font-weight: 700; font-size: 1.5rem; color: var(--primary-oxblood);">2022</div>
