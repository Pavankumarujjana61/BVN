<%- include('partials/header') %>

<!-- 1. Premium About Hero Section -->
<section class="hero-section" style="background-image: url('/images/factory_cnc.png'); min-height: 45vh;">
  <div class="hero-overlay" style="background-color: var(--primary-oxblood); opacity: 0.65;"></div>
  <div class="container hero-content" style="text-align: center; margin: 0 auto;">
    <h1 style="color: var(--bg-white); font-size: 3rem;" class="reveal">About BVN Modulars</h1>
    <p style="color: var(--bg-offwhite); font-size: 1.25rem;" class="reveal stagger-1">Building Trust Through Factory-Made Precision and Premium Quality</p>
  </div>
</section>

<!-- 2. The Factory Story Section (Alternating rhythm - White background) -->
<section class="about-story-section">
  <div class="container">
    <div style="display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 4rem; align-items: center;">
      <div class="reveal reveal-left">
        <h2 class="section-title" style="display: block; text-align: left;">Our Factory Story</h2>
        <p style="margin-top: 1.5rem; font-size: 1.05rem;">Founded in Rajahmundry, Andhra Pradesh, BVN Modulars was established to bridge the gap between traditional carpentry limitations and modern modular technology. For decades, homeowners in Tier 2 cities had to deal with unorganized local carpentry, leading to unpredictable timelines, messy on-site cutting, and moisture-absorbing board edges.</p>
        <p style="font-size: 1.05rem;">We pioneered local production by investing in a state-of-the-art 15,000 square feet manufacturing unit. Under strict factory oversight, we use automated German-spec CNC Router Machines and high-pressure edgebanders to construct modular furniture with 0.1mm dimensional precision. This ensures a clean layout fit and complete defense against humidity.</p>
      </div>
      <!-- Animated Image Showcase -->
      <div class="reveal reveal-right" style="position: relative;">
        <div style="position: relative; border-radius: 8px; overflow: hidden; box-shadow: var(--shadow-premium); border: 4px solid var(--accent-amber); aspect-ratio: 4/3;">
          <img src="/images/factory_cnc.png" alt="Factory CNC Router Machine at BVN Modulars" class="project-img" style="width: 100%; height: 100%; object-fit: cover;">
        </div>
        <!-- Accent decorative box -->
        <div style="position: absolute; bottom: -20px; left: -20px; width: 120px; height: 120px; background-color: var(--secondary-walnut); z-index: -1; border-radius: 4px;" class="reveal reveal-scale stagger-2"></div>
      </div>
    </div>
  </div>
</section>

<!-- 3. Core Values Section (Alternating rhythm - Warm Off-White background) -->
<section class="about-values-section" style="background-color: var(--bg-offwhite);">
  <div class="container">
    <div class="section-header reveal">
      <h2 class="section-title">Our Core Values</h2>
    </div>
    
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem; margin-top: 3.5rem;">
      <!-- Value 1 -->
      <div class="material-card reveal stagger-1" style="background-color: var(--bg-white); border-top-color: var(--primary-oxblood);">
        <div style="font-size: 2.25rem; color: var(--secondary-walnut); margin-bottom: 1rem;">🎯</div>
        <h3 style="color: var(--primary-oxblood); font-size: 1.25rem; margin-bottom: 0.75rem;">Millimeter Precision</h3>
        <p style="font-size: 0.95rem; margin-bottom: 0;">We trust machine precision. CNC cutting to 0.1mm accuracy ensures all cabinets, drawer runners, and hinge bores fit together perfectly without manual rework.</p>
      </div>

      <!-- Value 2 -->
      <div class="material-card reveal stagger-2" style="background-color: var(--bg-white); border-top-color: var(--primary-oxblood);">
        <div style="font-size: 2.25rem; color: var(--secondary-walnut); margin-bottom: 1rem;">🛡️</div>
        <h3 style="color: var(--primary-oxblood); font-size: 1.25rem; margin-bottom: 0.75rem;">Material Integrity</h3>
        <p style="font-size: 0.95rem; margin-bottom: 0;">We never use particle board or low-grade MDF. Wet areas feature 100% waterproof BWP marine plywood, and all hardware is sourced from global brands (Hettich, Hafele).</p>
      </div>

      <!-- Value 3 -->
      <div class="material-card reveal stagger-3" style="background-color: var(--bg-white); border-top-color: var(--primary-oxblood);">
        <div style="font-size: 2.25rem; color: var(--secondary-walnut); margin-bottom: 1rem;">🤝</div>
        <h3 style="color: var(--primary-oxblood); font-size: 1.25rem; margin-bottom: 0.75rem;">Customer Commitment</h3>
        <p style="font-size: 0.95rem; margin-bottom: 0;">No hidden quotes or missed deadlines. We provide itemized bills before signing, and our trained in-house installers assemble items without site mess.</p>
      </div>
    </div>
  </div>
</section>

<!-- 4. Our Mission & Vision (Alternating rhythm - White background) -->
<section class="about-mission-section">
  <div class="container">
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 4rem;">
      <div class="reveal reveal-left" style="background-color: var(--bg-offwhite); padding: 3rem; border-radius: 8px; border-left: 5px solid var(--secondary-walnut); box-shadow: var(--shadow-light);">
        <h3 style="font-size: 1.5rem; color: var(--primary-oxblood); margin-bottom: 1rem; font-family: 'Montserrat'; font-weight: 700;">Our Mission</h3>
        <p style="font-size: 1.05rem; margin-bottom: 0; color: var(--body-charcoal);">To deliver factory-made precision modular interiors directly to homeowners at transparent pricing. We aim to eliminate the delays and quality surprises of carpenter work by manufacturing furniture locally inside our Rajahmundry plant.</p>
      </div>
      
      <div class="reveal reveal-right" style="background-color: var(--bg-offwhite); padding: 3rem; border-radius: 8px; border-left: 5px solid var(--accent-amber); box-shadow: var(--shadow-light);">
        <h3 style="font-size: 1.5rem; color: var(--primary-oxblood); margin-bottom: 1rem; font-family: 'Montserrat'; font-weight: 700;">Our Vision</h3>
        <p style="font-size: 1.05rem; margin-bottom: 0; color: var(--body-charcoal);">To become Andhra Pradesh's most trusted factory-backed interior provider. We build long-term relationships by prioritizing durability (5-10 year warranty) and raising design standards in Tier 2 cities.</p>
      </div>
    </div>
  </div>
</section>

<!-- 5. Milestones & Timeline (Alternating rhythm - Warm Off-White background) -->
