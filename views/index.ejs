              <div class="contact-detail-text">
                <h4>Working Hours</h4>
                <p>Mon - Sat: 9:00 AM - 8:00 PM (Sunday Closed)</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Google Maps Embed of Rajahmundry Area -->
        <div class="map-embed-container">
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3814.9448323526794!2d81.8110899!3d17.026375899999998!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3a37a258bc0def87%3A0xa70c706e072e337!2sBVN%20modulars!5e0!3m2!1sen!2sin!4v1781945759448!5m2!1sen!2sin" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>

      <!-- Contact Form Side (Right Column, animated, premium layout) -->
      <div class="contact-form-side reveal reveal-right" style="border-top: 4px solid var(--secondary-walnut); box-shadow: var(--shadow-premium);">
        <h3>Send An Enquiry</h3>
        
        <% if (typeof success !== 'undefined' && success) { %>
          <div class="alert alert-success">Your enquiry was submitted successfully! We will get in touch with you shortly.</div>
        <% } %>
        
        <form action="/enquire" method="POST">
          <div class="form-group">
            <label for="name">Your Name *</label>
            <input type="text" id="name" name="name" class="form-control" placeholder="Enter your full name" required>
          </div>
          
          <div class="form-group">
            <label for="phone">Phone Number *</label>
            <!-- inputmode="numeric" triggers numeric keyboard on mobile -->
            <input type="tel" id="phone" name="phone" class="form-control" placeholder="Enter 10-digit mobile number" pattern="[0-9]{10}" inputmode="numeric" required>
          </div>
          
          <div class="form-group">
            <label for="city">City / Area *</label>
            <input type="text" id="city" name="city" class="form-control" placeholder="e.g. Innispeta, Rajahmundry" required>
          </div>
          
          <div class="form-group">
            <label for="service">Service Interested In *</label>
            <select id="service" name="service" class="form-control" required>
              <option value="" disabled selected>Select a service</option>
              <option value="Modular Kitchen">Modular Kitchen</option>
              <option value="Wardrobe & Storage">Wardrobe & Storage</option>
              <option value="TV Unit & Louvers">TV Unit & Louvers</option>
              <option value="Bedroom Furniture">Bedroom Furniture</option>
              <option value="Crockery Unit">Crockery Unit</option>
              <option value="Office Interiors">Office Interiors</option>
            </select>
          </div>
          
          <div class="form-group">
            <label for="message">Message (Optional)</label>
            <textarea id="message" name="message" class="form-control" placeholder="Tell us more about your space..."></textarea>
          </div>
          
          <button type="submit" class="btn form-submit-btn">Send My Enquiry</button>
        </form>
      </div>
    </div>
  </div>
