<%- include('partials/header') %>

<!-- 1. Hero Banner Slider Section (Automatic Scrolling) -->
<section class="hero-section hero-slider-container">
  <div class="hero-track">
    <% if (typeof banners !== 'undefined' && banners.length > 0) { %>
      <% banners.forEach((slide, index) => { %>
        <div class="hero-slide <%= index === 0 ? 'active' : '' %>" style="background-image: url('<%= slide.image %>');">
          <div class="hero-overlay" style="background-color: var(--primary-oxblood); opacity: 0.55;"></div>
          <div class="container hero-content">
            <h1><%= slide.title %></h1>
            <p><%= slide.subtitle %></p>
            <div class="hero-actions">
              <% if (slide.btn1Text) { %>
                <a href="<%= slide.btn1Url || '#contact-form' %>" class="btn btn-primary"><%= slide.btn1Text %></a>
              <% } %>
              <% if (slide.btn2Text) { %>
                <a href="<%= slide.btn2Url || '/projects' %>" class="btn btn-secondary"><%= slide.btn2Text %></a>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <!-- Fallback Slide if database is empty -->
      <div class="hero-slide active" style="background-image: url('/images/hero_kitchen.webp');">
        <div class="hero-overlay" style="background-color: var(--primary-oxblood); opacity: 0.55;"></div>
        <div class="container hero-content">
          <h1>Factory-Made Modular Interiors — Delivered to Your Door in Rajahmundry</h1>
          <p>Custom Kitchens, Wardrobes, TV Units &amp; More — Designed in 3D, Built in Our Own Factory</p>
          <div class="hero-actions">
            <a href="#contact-form" class="btn btn-primary">Get Free 3D Design Consultation</a>
            <a href="/projects" class="btn btn-secondary">View Our Projects</a>
          </div>
        </div>
      </div>
    <% } %>
  </div>
  
  <!-- Slide Navigation Indicators -->
  <div class="hero-slider-dots">
    <% if (typeof banners !== 'undefined' && banners.length > 0) { %>
      <% banners.forEach((_, index) => { %>
        <span class="hero-dot <%= index === 0 ? 'active' : '' %>" data-slide="<%= index %>"></span>
      <% }) %>
    <% } else { %>
      <span class="hero-dot active" data-slide="0"></span>
    <% } %>
  </div>
</section>


