<%- include('partials/header') %>

<section class="blog-post-header">
  <div class="container">
    <h1>Customer Reviews</h1>
    <div class="blog-post-meta">What Our Clients Say About BVN Modulars</div>
  </div>
</section>

<section class="testimonials-page-section">
  <div class="container">
    <div style="max-width: 800px; margin: 0 auto; margin-bottom: 4rem; text-align: center;">
      <p style="font-size: 1.1rem;">Verified reviews from real homeowners in Rajahmundry, Danavaipeta, Innispeta, and T-Nagar. Our factory-made solutions deliver top satisfaction.</p>
    </div>

    <div style="display: flex; flex-direction: column; gap: 3rem; max-width: 900px; margin: 0 auto;">
      <% testimonials.forEach(testimonial => { %>
        <div class="testimonial-card" style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 2.5rem; background-color: var(--bg-offwhite); border: 1px solid var(--secondary-walnut); border-radius: 8px; padding: 2.5rem;">
          <div class="testimonial-text-side">
            <div class="customer-info">
              <div class="customer-name" style="font-size: 1.25rem;"><%= testimonial.customerName %></div>
              <div class="customer-area" style="font-size: 0.9rem; color: var(--secondary-walnut); font-weight: 600;"><%= testimonial.location %></div>
            </div>
            <div class="rating-stars" style="color: var(--accent-amber); font-size: 1.2rem; margin-top: 0.5rem; margin-bottom: 1.25rem;">
              <% for(let i=0; i<testimonial.rating; i++) { %>★<% } %>
            </div>
            <p class="testimonial-quote" style="font-style: italic; font-size: 1.05rem;">"<%= testimonial.text %>"</p>
            <span class="testimonial-service-tag" style="background-color: rgba(120, 68, 25, 0.08); padding: 0.4rem 0.8rem; border-radius: 4px; font-family: 'Montserrat'; font-weight: 600; font-size: 0.8rem; color: var(--secondary-walnut); text-transform: uppercase; align-self: flex-start; display: inline-block; margin-top: 1rem;"><%= testimonial.serviceType %></span>
          </div>
          
          <div class="testimonial-media-side">
            <div class="testimonial-photos" style="display: grid; grid-template-columns: 80px 1fr; gap: 1rem; align-items: center;">
              <img src="<%= testimonial.customerPhoto %>" alt="<%= testimonial.customerName %> portrait" class="customer-photo" style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 2px solid var(--secondary-walnut);">
              <img src="<%= testimonial.projectPhoto %>" alt="Completed modular project for <%= testimonial.customerName %>" class="project-photo-preview" style="width: 100%; height: 140px; border-radius: 6px; object-fit: cover; border: 1px solid var(--bg-white);">
            </div>
            <% if(testimonial.videoEmbed) { %>
              <div class="video-embed-container" style="position: relative; padding-bottom: 56.25%; height: 0; border-radius: 6px; overflow: hidden; margin-top: 1rem;">
                <iframe src="<%= testimonial.videoEmbed %>" allowfullscreen style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0;"></iframe>
              </div>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
